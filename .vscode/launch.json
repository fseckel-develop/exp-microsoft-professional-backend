{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Launch C5 API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build C5",
      "program": "${workspaceFolder}/projects/C5-user-management-api/bin/Debug/net10.0/C5-user-management-api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/projects/C5-user-management-api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "console": "integratedTerminal"
    },
    {
      "name": ".NET Attach to Process",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
