@LogiTrack_HostAddress = http://localhost:5112


########################################################################
# Inventory endpoints
########################################################################


# READ all inventory items (should return empty initially)
GET {{LogiTrack_HostAddress}}/api/inventory
Accept: application/json

###


# CREATE a valid inventory item
POST {{LogiTrack_HostAddress}}/api/inventory
Content-Type: application/json

{
  "name": "Widget",
  "quantityInStock": 100,
  "price": 19.99,
  "location": "A1"
}

######


# CREATE an invalid inventory item (missing required field Name)
POST {{LogiTrack_HostAddress}}/api/inventory
Content-Type: application/json

{
  "quantityInStock": 5,
  "price": 2.50,
  "location": "B2"
}

######


# UPDATE an existing inventory item
PUT {{LogiTrack_HostAddress}}/api/inventory/5
Content-Type: application/json

{
  "itemId": 2,
  "name": "Widget Pro",
  "quantityInStock": 150,
  "price": 24.99,
  "location": "A1"
}

######


# UPDATE non-existing item (should return 404)
PUT {{LogiTrack_HostAddress}}/api/inventory/9999
Content-Type: application/json

{
  "itemId": 9999,
  "name": "Ghost",
  "quantityInStock": 1,
  "price": 1.00,
  "location": "Z9"
}

######


# DELETE inventory item (replace 1 with actual id)
DELETE {{LogiTrack_HostAddress}}/api/inventory/6

######


# DELETE non-existing inventory item
DELETE {{LogiTrack_HostAddress}}/api/inventory/9999

######




########################################################################
# Orders endpoints
########################################################################


# READ all orders (should return empty initially)
GET {{LogiTrack_HostAddress}}/api/orders
Accept: application/json

######


# CREATE a new order with items
POST {{LogiTrack_HostAddress}}/api/orders
Content-Type: application/json

{
  "customerName": "Acme Corp",
  "orderItems": [
    {
      "inventoryItemId": 1,
      "quantityOrdered": 2
    },
    {
      "inventoryItemId": 2,
      "quantityOrdered": 1
    }
  ]
}

######


# READ order by ID
GET {{LogiTrack_HostAddress}}/api/orders/3
Accept: application/json

######


# CREATE a new InventoryItem to an existing order
POST {{LogiTrack_HostAddress}}/api/orders/3/items
Content-Type: application/json

{
  "inventoryItemId": 5,
  "quantityOrdered": 5
}

######


# UPDATE quantity of an existing item, increasing by 3
PATCH {{LogiTrack_HostAddress}}/api/orders/1/items/2?quantityChange=3

######


# UPDATE quantity of an existing item, decreasing by 1 (should remove it if quantity reaches 0)
PATCH {{LogiTrack_HostAddress}}/api/orders/1/items/2?quantityChange=-1

######


# DELETE an item from a given order
DELETE {{LogiTrack_HostAddress}}/api/orders/3/items/1

######


# UPDATE order info (e.g., change CustomerName)
PATCH {{LogiTrack_HostAddress}}/api/orders/3
Content-Type: application/json

{
  "customerName": "Acme Corporation Ltd."
}

######


# DELETE an existent order
DELETE {{LogiTrack_HostAddress}}/api/orders/3

######


# DELETE a non-existent order (should return 404)
DELETE {{LogiTrack_HostAddress}}/api/orders/999
Accept: application/json

#####
