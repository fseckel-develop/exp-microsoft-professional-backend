@LogiTrack_HostAddress = http://localhost:5112


########################################################################
# General Auth Flow for a normal user (no role)
########################################################################

# REGISTER a new plain user (requires email confirmation before login)
POST {{LogiTrack_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "email": "plainuser@example.com",
  "password": "Password123!"
}
######


# LOGIN before email confirmation (should fail)
POST {{LogiTrack_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "plainuser@example.com",
  "password": "Password123!"
}
######


# CONFIRM EMAIL manually
# Copy the confirmation link printed by FakeEmailSender in the console
# and paste the userId + token below
GET {{LogiTrack_HostAddress}}/api/auth/confirm-email?userId=PASTE_USER_ID&token=PASTE_TOKEN
######


# LOGIN after email confirmation (should pass)
POST {{LogiTrack_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "plainuser@example.com",
  "password": "Password123!"
}

# Paste the returned JWT manually here after successful login
@AccessToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..4t2Uk8xbAlnpBX11NPGYQfAw1M8dVN3M9m5tIfFUi_c

# Paste the refreshToken cookie value manually here if needed
@RefreshToken = 4yh1VyXrr2%2FrFJds3Uz8KO43pcV3PjXdcgjksfnpbRg%3D

######


# LOGIN with invalid password (should fail)
POST {{LogiTrack_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "plainuser@example.com",
  "password": "WrongPassword!"
}
######


# REFRESH TOKEN manually using copied refresh cookie value
POST {{LogiTrack_HostAddress}}/api/auth/refresh-token
Cookie: refreshToken={{RefreshToken}}
Accept: application/json
######


# LOGOUT authenticated user
POST {{LogiTrack_HostAddress}}/api/auth/logout
Authorization: Bearer {{AccessToken}}
Cookie: refreshToken={{RefreshToken}}
######