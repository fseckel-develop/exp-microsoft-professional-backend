### Variables
@BaseAddress = http://localhost:5291
@ValidToken = Bearer my-secret-token
@InvalidToken = Bearer invalid-token


##################################################
# Create
##################################################

### Create user - valid
POST {{BaseAddress}}/users
Authorization: {{ValidToken}}
Content-Type: application/json

{
  "name": "Alice",
  "email": "alice@example.com"
}

### Create user - invalid (empty name)
POST {{BaseAddress}}/users
Authorization: {{ValidToken}}
Content-Type: application/json

{
  "name": "",
  "email": "bob@example.com"
}

### Create user - invalid (bad email)
POST {{BaseAddress}}/users
Authorization: {{ValidToken}}
Content-Type: application/json

{
  "name": "Charlie",
  "email": "invalid-email"
}

### Create user - invalid (missing name)
POST {{BaseAddress}}/users
Authorization: {{ValidToken}}
Content-Type: application/json

{
  "email": "missing.name@example.com"
}

### Create user - invalid (missing email)
POST {{BaseAddress}}/users
Authorization: {{ValidToken}}
Content-Type: application/json

{
  "name": "Missing Email"
}

### Create user - unauthorized
POST {{BaseAddress}}/users
Authorization: {{InvalidToken}}
Content-Type: application/json

{
  "name": "Eve",
  "email": "eve@example.com"
}

### Create user - missing Authorization header
POST {{BaseAddress}}/users
Content-Type: application/json

{
  "name": "No Token",
  "email": "no.token@example.com"
}


##################################################
# Read
##################################################

### Get all users
GET {{BaseAddress}}/users
Authorization: {{ValidToken}}

### Get all users - unauthorized
GET {{BaseAddress}}/users
Authorization: {{InvalidToken}}

### Get all users - missing Authorization header
GET {{BaseAddress}}/users

### Get user by ID - existing
GET {{BaseAddress}}/users/1
Authorization: {{ValidToken}}

### Get user by ID - non-existent
GET {{BaseAddress}}/users/999
Authorization: {{ValidToken}}

### Get user by ID - unauthorized
GET {{BaseAddress}}/users/1
Authorization: {{InvalidToken}}

### Get user by ID - invalid route value
GET {{BaseAddress}}/users/abc
Authorization: {{ValidToken}}


##################################################
# Update
##################################################

### Update user - valid
PUT {{BaseAddress}}/users/1
Authorization: {{ValidToken}}
Content-Type: application/json

{
  "name": "Alice Updated",
  "email": "alice.updated@example.com"
}

### Update user - invalid (empty name)
PUT {{BaseAddress}}/users/1
Authorization: {{ValidToken}}
Content-Type: application/json

{
  "name": "",
  "email": "alice.updated@example.com"
}

### Update user - invalid (bad email)
PUT {{BaseAddress}}/users/1
Authorization: {{ValidToken}}
Content-Type: application/json

{
  "name": "Alice Updated",
  "email": "not-an-email"
}

### Update user - invalid (missing email)
PUT {{BaseAddress}}/users/1
Authorization: {{ValidToken}}
Content-Type: application/json

{
  "name": "Alice Updated"
}

### Update user - non-existent
PUT {{BaseAddress}}/users/999
Authorization: {{ValidToken}}
Content-Type: application/json

{
  "name": "Nobody",
  "email": "nobody@example.com"
}

### Update user - unauthorized
PUT {{BaseAddress}}/users/1
Authorization: {{InvalidToken}}
Content-Type: application/json

{
  "name": "Hacker",
  "email": "hacker@example.com"
}

### Update user - missing Authorization header
PUT {{BaseAddress}}/users/1
Content-Type: application/json

{
  "name": "No Token Update",
  "email": "no.token.update@example.com"
}


##################################################
# Delete
##################################################

### Delete user - existing
DELETE {{BaseAddress}}/users/1
Authorization: {{ValidToken}}

### Delete user - non-existent
DELETE {{BaseAddress}}/users/999
Authorization: {{ValidToken}}

### Delete user - unauthorized
DELETE {{BaseAddress}}/users/1
Authorization: {{InvalidToken}}

### Delete user - missing Authorization header
DELETE {{BaseAddress}}/users/1


##################################################
# Notes
##################################################

### Typical demo flow:
### 1. Create one or two valid users
### 2. Read all users
### 3. Read one user by ID
### 4. Update that user
### 5. Delete that user
###
### Since this API uses an in-memory singleton store, request order affects later results.