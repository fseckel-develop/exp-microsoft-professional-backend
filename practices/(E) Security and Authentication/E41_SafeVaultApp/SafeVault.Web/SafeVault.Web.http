@SafeVaultWeb_HostAddress = http://localhost:5209

GET {{SafeVaultWeb_HostAddress}}/webform.html
Accept: application/json

### Register a normal user
POST {{SafeVaultWeb_HostAddress}}/register
Content-Type: application/x-www-form-urlencoded

username=user1&password=UserPass123!&email=user1@example.com&role=User

### Register an admin user
POST {{SafeVaultWeb_HostAddress}}/register
Content-Type: application/x-www-form-urlencoded

username=admin1&password=AdminPass123!&email=admin1@example.com&role=Admin

### Login with valid user credentials
POST {{SafeVaultWeb_HostAddress}}/login
Content-Type: application/x-www-form-urlencoded

username=user1&password=UserPass123!

### Login with invalid password
POST {{SafeVaultWeb_HostAddress}}/login
Content-Type: application/x-www-form-urlencoded

username=user1&password=WrongPassword!

### Login with non-existent user
POST {{SafeVaultWeb_HostAddress}}/login
Content-Type: application/x-www-form-urlencoded

username=ghost&password=anything

### Access admin dashboard as admin
GET {{SafeVaultWeb_HostAddress}}/admin/dashboard?username=admin1

### Access admin dashboard as regular user (should be unauthorized)
GET {{SafeVaultWeb_HostAddress}}/admin/dashboard?username=user1

### Access admin dashboard as unknown user (should be unauthorized)
GET {{SafeVaultWeb_HostAddress}}/admin/dashboard?username=ghost

