### Register normal user
POST {{BaseAddress}}/api/auth/register
Content-Type: application/json

{
  "username": "user",
  "email": "user@example.com",
  "password": "Password123!",
  "role": "User"
}

### Register admin user
POST {{BaseAddress}}/api/auth/register
Content-Type: application/json

{
  "username": "adminuser",
  "email": "admin@example.com",
  "password": "Password123!",
  "role": "Admin"
}

### Register duplicate username
POST {{BaseAddress}}/api/auth/register
Content-Type: application/json

{
  "username": "user",
  "email": "user2@example.com",
  "password": "Password123!",
  "role": "User"
}

### Register invalid email
POST {{BaseAddress}}/api/auth/register
Content-Type: application/json

{
  "username": "bademail",
  "email": "not-an-email",
  "password": "Password123!",
  "role": "User"
}

### Register invalid role
POST {{BaseAddress}}/api/auth/register
Content-Type: application/json

{
  "username": "stranger",
  "email": "stranger@example.com",
  "password": "Password123!",
  "role": "SuperAdmin"
}

### Login as normal user
POST {{BaseAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "user",
  "password": "Password123!"
}

### Login as admin user
POST {{BaseAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "adminuser",
  "password": "Password123!"
}

### Login with wrong password
POST {{BaseAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "user",
  "password": "WrongPassword!"
}

### Login with unknown user
POST {{BaseAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "nobody",
  "password": "Password123!"
}

### Access admin dashboard without token
GET {{BaseAddress}}/api/admin/dashboard

### Access admin dashboard with non-admin token
GET {{BaseAddress}}/api/admin/dashboard
Authorization: Bearer {{UserToken}}

### Access admin dashboard with admin token
GET {{BaseAddress}}/api/admin/dashboard
Authorization: Bearer {{AdminToken}}