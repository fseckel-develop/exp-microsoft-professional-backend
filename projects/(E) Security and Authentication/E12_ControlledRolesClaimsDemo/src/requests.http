@baseUrl = http://localhost:5150

############################################
# 0️⃣ Public Home Page (MVC)
############################################
GET {{baseUrl}}/

###

############################################
# 1️⃣ Register NORMAL user (MVC form)
############################################
POST {{baseUrl}}/Account/Register
Content-Type: application/x-www-form-urlencoded

Email=user1@example.com&
Password=Password@123&
ConfirmPassword=Password@123

###

############################################
# 2️⃣ Login NORMAL user (MVC form)
############################################
POST {{baseUrl}}/Account/Login
Content-Type: application/x-www-form-urlencoded

Email=user1@example.com&
Password=Password@123&
RememberMe=false

###

############################################
# 3️⃣ Access Public API endpoint (no auth)
############################################
GET {{baseUrl}}/api/protected/public

###

############################################
# 4️⃣ Access Admin-only API (should FAIL → 403)
############################################
GET {{baseUrl}}/api/protected/admin-only

###

############################################
# 5️⃣ Logout NORMAL user
############################################
POST {{baseUrl}}/Account/Logout
Content-Type: application/x-www-form-urlencoded

###

############################################
# 6️⃣ Login SEEDED ADMIN (MVC form)
############################################
POST {{baseUrl}}/Account/Login
Content-Type: application/x-www-form-urlencoded

Email=admin@example.com&
Password=Admin@123&
RememberMe=false

###

############################################
# 7️⃣ Access Admin-only API (should PASS)
############################################
GET {{baseUrl}}/api/protected/admin-only

###

############################################
# 8️⃣ Assign Admin role to NORMAL user (MVC form)
############################################
POST {{baseUrl}}/Roles/Assign
Content-Type: application/x-www-form-urlencoded

email=user1@example.com&
role=Admin

###

############################################
# 9️⃣ Logout ADMIN
############################################
POST {{baseUrl}}/Account/Logout
Content-Type: application/x-www-form-urlencoded

###

############################################
# 🔟 Login NORMAL user again (now Admin)
############################################
POST {{baseUrl}}/Account/Login
Content-Type: application/x-www-form-urlencoded

Email=user1@example.com&
Password=Password@123&
RememberMe=false

###

############################################
# 1️⃣1️⃣ Admin-only API (now PASS)
############################################
GET {{baseUrl}}/api/protected/admin-only

###

############################################
# 1️⃣2️⃣ IT-only API (should FAIL)
############################################
GET {{baseUrl}}/api/protected/it-only

###

############################################
# 1️⃣3️⃣ Add IT Department claim to logged-in user
############################################
POST {{baseUrl}}/Account/AddClaim
Content-Type: application/x-www-form-urlencoded

claimType=Department&
claimValue=IT

###

############################################
# 1️⃣4️⃣ IT-only API (now PASS)
############################################
GET {{baseUrl}}/Protected/ITOnly

###

############################################
# 1️⃣5️⃣ MVC Roles Page (Admin only)
############################################
GET {{baseUrl}}/Roles

###